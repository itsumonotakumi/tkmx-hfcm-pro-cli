#!/usr/bin/env php
<?php

declare(strict_types=1);

// オートローダー (PSR-4 スタイル、Composer 不要)
spl_autoload_register(function (string $class): void {
    if (!str_starts_with($class, 'Tkmx\\HfcmCli\\')) {
        return;
    }
    $relative = substr($class, strlen('Tkmx\\HfcmCli\\'));
    $file = __DIR__ . '/../src/' . str_replace('\\', '/', $relative) . '.php';
    if (is_file($file)) {
        require $file;
    }
});

require __DIR__ . '/../src/Bootstrap.php';

\Tkmx\HfcmCli\Bootstrap::init($argv);

// SIGTERM/SIGINT ハンドラーを登録し、シグナルで ExecutionLock が解放されることを保証
if (function_exists('pcntl_async_signals')) {
    pcntl_async_signals(true);
    $signalHandler = function (int $signal) use ($argv): void {
        \Tkmx\HfcmCli\Support\ExecutionLock::releaseIfOwner();
        exit(130);
    };
    if (function_exists('pcntl_signal')) {
        pcntl_signal(SIGTERM, $signalHandler);
        pcntl_signal(SIGINT, $signalHandler);
    }
}

try {
    exit((new \Tkmx\HfcmCli\Router())->dispatch($argv));
} catch (\Tkmx\HfcmCli\Support\PayloadException $e) {
    fwrite(STDERR, "Error: " . $e->getMessage() . "\n");
    exit($e->getExitCode());
}
